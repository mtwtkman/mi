#!/bin/bash

TRUE=1
FALSE=0

function is_boxable()
{
  [[ -e "box" ]] && [[ -e "distrobox.ini" ]] && echo $TRUE || echo $FALSE
}

function climb()
{
  cd ../
}

here=$(pwd)
found=$FALSE
depth=0

while ([ $found == $FALSE ] && [ "$(pwd)" != "/" ]); do
  found=$(is_boxable)
  [[ $found == $FALSE ]] && depth=$((depth + 1)) && climb
done

[ $found == $FALSE ] && echo "box cannot be found" && exit 0

cd "${here}"
path=""
for i in $(seq 1 ${depth}); do
  path="../${path}"
done
./${path}box e
